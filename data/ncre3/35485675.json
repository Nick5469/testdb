        "number": "0",
        "options": "[{\"Key\":\"A\",\"Value\":\"<p>\\u4e24\\u4e2a\\u6838\\u5fc3\\u8def\\u7531\\u5668\\u4e4b\\u95f4\\u91c7\\u53d6\\u5197\\u4f59\\u94fe\\u8def\\u7684\\u5149\\u7ea4\\u8fde\\u63a5<\\\/p>\"},{\"Key\":\"B\",\"Value\":\"<p>\\u6838\\u5fc3\\u5c42\\u76ee\\u524d\\u4e3b\\u8981\\u91c7\\u7528GE\\\/10GE\\u7f51\\u7edc\\u6280\\u672f<\\\/p>\"},{\"Key\":\"C\",\"Value\":\"<p>\\u65b9\\u6848\\uff08b\\uff09\\u6838\\u5fc3\\u8def\\u7531\\u5668\\u7684\\u6d41\\u91cf\\u538b\\u529b\\u66f4\\u5927<\\\/p>\"},{\"Key\":\"D\",\"Value\":\"<p>\\u65b9\\u6848\\uff08b\\uff09\\u6613\\u5f62\\u6210\\u5355\\u70b9\\u6545\\u969c<\\\/p>\"}]",
